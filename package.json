{
  "name": "@davidsneighbour/nanny",
  "description": "Repo management and maintenance CLI for davidsneighbour projects.",
  "version": "0.1.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidsneighbour/nanny.git"
  },
  "dependencies": {
    "@release-it/conventional-changelog": "11.0.0",
    "fast-glob": "3.3.3",
    "jsonc-parser": "3.3.1",
    "release-it": "20.0.1"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "typescript": "6.0.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ci": "npm run typecheck && npm run build",
    "prepublishOnly": "npm run build",
    "release": "npm run ci && release-it",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "nanny": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "type": "module"
}
