{
  "name": "@davidsneighbour/nanny",
  "description": "Repo management and maintenance CLI for davidsneighbour projects.",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidsneighbour/nanny.git"
  },
  "dependencies": {
    "@release-it/conventional-changelog": "11.0.0",
    "c12": "3.3.3",
    "confbox": "0.2.4",
    "fast-glob": "3.3.3",
    "release-it": "20.0.1"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ci": "npm run typecheck && npm run build",
    "prepublishOnly": "npm run build",
    "release": "npm run ci && release-it",
    "test:package-init": "npm run build && node dist/tests/package-init.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "nanny": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "type": "module"
}
